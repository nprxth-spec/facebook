generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Server-side rate limiting for Facebook syncs (10-min cooldown)
  lastFbPagesSyncAt    DateTime?
  lastFbAccountsSyncAt DateTime?

  accounts          Account[]
  sessions          Session[]
  exportConfigs     ExportConfig[]
  exportLogs        ExportLog[]
  managerAccounts   ManagerAccount[]
  facebookPages     FacebookPage[]
  preferences       UserPreferences?
  interestPresets   InterestAudiencePreset[]
  messengerTemplates MessengerTemplate[]
  aiUsages         AiUsage[]
  activityLogs     UserActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ManagerAccount {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  name      String
  platform  String   @default("facebook")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model FacebookPage {
  id         String   @id @default(cuid())
  userId     String
  pageId     String
  name       String
  username   String?
  pageStatus String?
  pictureUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model ExportConfig {
  id              String   @id @default(cuid())
  userId          String
  name            String
  adAccountIds    String[]
  googleSheetId   String
  googleSheetName String
  sheetTab        String
  columnMapping   Json
  writeMode       String   @default("append")
  isAuto          Boolean  @default(false)
  autoSchedule    String?
  dateRange       String   @default("today")
  autoDays        Int[]    @default([0, 1, 2, 3, 4, 5, 6])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exportLogs ExportLog[]
}

model ExportLog {
  id              String   @id @default(cuid())
  userId          String
  configId        String?
  configName      String?
  exportType      String
  sheetFileName   String?
  sheetTabName    String?
  adAccountCount  Int      @default(0)
  rowCount        Int      @default(0)
  dataDate        DateTime?
  status          String   @default("success")
  error           String?
  details         Json?    @db.JsonB
  createdAt       DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  config ExportConfig? @relation(fields: [configId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, status])
}

/// บันทึกกิจกรรมสำคัญของผู้ใช้ เช่น login, export, billing
model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // เช่น login, export_run, billing_subscribe
  category  String   // เช่น auth, export, billing, admin, system
  method    String?  // HTTP method หรือ OAuth เป็นต้น
  path      String?  // URL path หรือ endpoint
  ip        String?
  userAgent String?
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([category, createdAt])
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("light")
  accentColor String @default("blue")
  language  String   @default("th")
  timezone  String   @default("Asia/Bangkok")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestAudiencePreset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  interests   Json     // เก็บ Array ของ { id: string, name: string }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model MessengerTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  greeting    String
  iceBreakers Json     // Array of { question: string, payload: string }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

/// ประวัติการใช้งาน Free Trial ตามอีเมล เพื่อกันลบแล้วสมัครใหม่ใช้สิทธิ์ซ้ำ
model TrialHistory {
  id                  String   @id @default(cuid())
  email               String   @unique
  firstSignupAt       DateTime
  freeTrialStartedAt  DateTime
  freeTrialExpiredAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// เก็บการใช้เครดิต AI ต่อผู้ใช้ในแต่ละเดือน (สำหรับฟีเจอร์ AI ต่าง ๆ)
model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  month     String   // รูปแบบเช่น '2026-03'
  used      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

